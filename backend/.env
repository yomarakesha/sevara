# ─── PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sillbridge
DB_USER=postgres
DB_PASSWORD=postgres

# ─── JWT ──────────────────────────────────────
JWT_SECRET=aravesdna28_@
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS (frontend URL — also used to build reset links) ──────────────
FRONTEND_URL=http://localhost:5500

# ─── Cron ─────────────────────────────────────
# Time zone for the daily / weekly XP reset jobs.
# Examples: "UTC", "Asia/Ashgabat", "Europe/Moscow", "America/New_York"
CRON_TZ=UTC

# ─── Email (Nodemailer) ───────────────────────
# Leave these blank in dev — reset emails will be logged to the console.
# In production set them to a real SMTP provider (Mailgun, SendGrid, SES, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SillBridge <no-reply@sillbridge.dev>
